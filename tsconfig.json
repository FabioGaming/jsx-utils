{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["src/*"]
    },

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src"]
}
